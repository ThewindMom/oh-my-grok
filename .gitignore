__pycache__/
*.pyc
.DS_Store
*.bak
.omg/

# Go module vendor (never at repo root — conflicts with MCP vendor/)
vendor/github.com/
vendor/modules.txt

# MCP vendor: commit dist/ only; rebuild with scripts/build-mcp-runtimes.sh
vendor/ast-grep-core/
vendor/*/node_modules/
vendor/ast-grep-mcp/*
!vendor/ast-grep-mcp/dist/
vendor/lsp-tools-mcp/*
!vendor/lsp-tools-mcp/dist/
# Allow lazycodex-hooks node_modules symlink for lsp-daemon resolution
!vendor/lazycodex-hooks/node_modules/
!vendor/lazycodex-hooks/node_modules/@code-yeongyu/
!vendor/lazycodex-hooks/node_modules/@code-yeongyu/lsp-daemon
