{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" session-start",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/rules/dist/cli.js\" hook session-start",
            "timeout": 10,
            "statusMessage": "(OmO) Loading Project Rules"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/bootstrap/dist/cli.js\" hook session-start",
            "timeout": 30,
            "statusMessage": "(OmO) Checking Bootstrap Provisioning"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/telemetry/dist/cli.js\" hook session-start",
            "timeout": 5,
            "statusMessage": "(OmO) Recording Session Telemetry"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/codegraph/dist/cli.js\" hook session-start",
            "timeout": 5,
            "statusMessage": "(OmO) Checking CodeGraph Bootstrap"
          }
        ]
      },
      {
        "matcher": "^startup$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/scripts/auto-update.mjs\" hook session-start",
            "timeout": 5,
            "statusMessage": "(OmO) Checking Auto Update"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" user-prompt",
            "timeout": 20
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/ultrawork/dist/cli.js\" hook user-prompt-submit",
            "timeout": 5,
            "statusMessage": "(OmO) Checking Ultrawork Trigger"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/ulw-loop/dist/cli.js\" hook user-prompt-submit",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Ulw-Loop Steering"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/rules/dist/cli.js\" hook user-prompt-submit",
            "timeout": 10,
            "statusMessage": "(OmO) Loading Project Rules"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|StrReplace|EditNotebook|Delete|search_replace|write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" pre-tool-use",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^run_terminal_command$|^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/git-bash/dist/cli.js\" hook pre-tool-use",
            "timeout": 5,
            "statusMessage": "(OmO) Recommending Git Bash MCP"
          }
        ]
      },
      {
        "matcher": "^update_goal$|^create_goal$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/ulw-loop/dist/cli.js\" hook pre-tool-use",
            "timeout": 5,
            "statusMessage": "(OmO) Enforcing Unlimited Goal Budget"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|read_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-tool-read",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "TodoWrite|todo_write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-tool-todo-write",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-tool-lsp",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-tool-comment-check",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|write|apply_patch|edit|multi_edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/comment-checker/dist/cli.js\" hook post-tool-use",
            "timeout": 30,
            "statusMessage": "(OmO) Checking Comments"
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|write|apply_patch|edit|multi_edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/lsp/dist/cli.js\" hook post-tool-use",
            "timeout": 60,
            "statusMessage": "(OmO) Checking LSP Diagnostics"
          }
        ]
      },
      {
        "matcher": "Write|StrReplace|search_replace|write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/rules/dist/cli.js\" hook post-tool-use",
            "timeout": 10,
            "statusMessage": "(OmO) Matching Project Rules"
          }
        ]
      },
      {
        "matcher": "create_thread|codex_app\\.create_thread",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/teammode/dist/cli.js\" hook post-tool-use",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Thread Title Hygiene"
          }
        ]
      },
      {
        "matcher": "codegraph[._].*|mcp__codegraph__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/codegraph/dist/cli.js\" hook post-tool-use",
            "timeout": 5,
            "statusMessage": "(OmO) Checking CodeGraph Init Guidance"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-tool-failure",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" permission-denied",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" stop",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/start-work-continuation/dist/cli.js\" hook stop",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Start-Work Continuation"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" stop-failure",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" notification",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" subagent-start",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" subagent-stop",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/start-work-continuation/dist/cli.js\" hook subagent-stop",
            "timeout": 10,
            "statusMessage": "(OmO) Checking Start-Work Continuation"
          }
        ]
      },
      {
        "matcher": "^lazygrok-executor$|^lazycodex-executor$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/lazycodex-executor-verify/dist/cli.js\" hook subagent-stop",
            "timeout": 10,
            "statusMessage": "(OmO) Verifying LazyCodex Executor Evidence"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" post-compact",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/rules/dist/cli.js\" hook post-compact",
            "timeout": 10,
            "statusMessage": "(OmO) Resetting Project Rule Cache"
          }
        ]
      },
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/lsp/dist/cli.js\" hook post-compact",
            "timeout": 5,
            "statusMessage": "(OmO) Resetting LSP Diagnostics Cache"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/vendor/lazygrok-hooks/git-bash/dist/cli.js\" hook post-compact",
            "timeout": 5,
            "statusMessage": "(OmO) Resetting Git Bash MCP Reminder"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/run-hook.sh\" session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
